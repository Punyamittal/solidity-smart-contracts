pragma solidity ^0.8.0;

contract Student {

    string public name;
    uint public age;

    constructor(string memory _name, uint _age) {
        name = _name;
        age = _age;
    }

    function updateAge(uint _age) public {
        age = _age;
    }

    function birthday() public {
        age++;
    }
}
